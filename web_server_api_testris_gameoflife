)rawliteral";
    request->send(200, "text/html", html);
  });

  // === API ===
  server.on("/api/status", HTTP_GET, [](AsyncWebServerRequest *request) {
    String s = (currentMode == MODE_TETRIS) ? "tetris" : (currentMode == MODE_CUSTOM ? "custom" : "gameoflife");
    request->send(200, "text/plain", s);
  });

  server.on("/api/mode", HTTP_GET, [](AsyncWebServerRequest *request) {
    if (request->hasParam("set")) {
      String m = request->getParam("set")->value();
      if (m == "tetris") { currentMode = MODE_TETRIS; memset(board,0,sizeof(board)); spawnPiece(); computeBestPlacement(); }
      else if (m == "custom") currentMode = MODE_CUSTOM;
      else if (m == "gameoflife") { currentMode = MODE_GAMEOFLIFE; initGameOfLife(); }
    }
    request->send(200, "text/plain", "OK");
  });

  server.on("/api/brightness", HTTP_GET, [](AsyncWebServerRequest *request) {
    if (request->hasParam("val")) pixels.setBrightness(request->getParam("val")->value().toInt());
    request->send(200, "text/plain", "OK");
  });

  server.begin();
  Serial.println("✅ All servers started!");
}

// ==================== LOOP ====================
void loop() {
  unsigned long now = millis();

  // TETRIS
  if (currentMode == MODE_TETRIS) {
    if (currentRot != targetRot) { int old = currentRot; currentRot = (currentRot+1)%4; if (collides()) currentRot = old; }
    if (currentX < targetX) { currentX++; if (collides()) currentX--; }
    else if (currentX > targetX) { currentX--; if (collides()) currentX++; }

    if (now - lastDrop >= dropInterval) {
      lastDrop = now; currentY++;
      if (collides()) { currentY--; lockPiece(); clearLines(); spawnPiece(); computeBestPlacement(); }
    }
  }

  // GAME OF LIFE
  if (currentMode == MODE_GAMEOFLIFE && now - lastGolUpdate >= golInterval) {
    lastGolUpdate = now;
    updateGameOfLife();
  }

  // UDP (images + commands)
  int packetSize = udp.parsePacket();
  if (packetSize > 0) {
    uint8_t buffer[1024];
    int len = udp.read(buffer, sizeof(buffer));
    if (len == NUM * 3) {  // raw 16x16 RGB image
      for (int i = 0; i < NUM; i++) customPixels[i] = pixels.Color(buffer[i*3], buffer[i*3+1], buffer[i*3+2]);
      currentMode = MODE_CUSTOM;
      udp.beginPacket(udp.remoteIP(), udp.remotePort()); udp.print("IMAGE_OK"); udp.endPacket();
    } else if (len > 0 && len < 50) {
      buffer[len] = 0; String cmd = String((char*)buffer); cmd.trim();
      if (cmd == "tetris")     { currentMode = MODE_TETRIS; memset(board,0,sizeof(board)); spawnPiece(); computeBestPlacement(); udp.beginPacket(udp.remoteIP(), udp.remotePort()); udp.print("MODE_TETRIS"); udp.endPacket(); }
      else if (cmd == "custom")     { currentMode = MODE_CUSTOM; udp.beginPacket(udp.remoteIP(), udp.remotePort()); udp.print("MODE_CUSTOM"); udp.endPacket(); }
      else if (cmd == "gameoflife") { currentMode = MODE_GAMEOFLIFE; initGameOfLife(); udp.beginPacket(udp.remoteIP(), udp.remotePort()); udp.print("MODE_GAMEOFLIFE"); udp.endPacket(); }
    }
  }

  draw();
  pixels.show();
  delay(30);
}
